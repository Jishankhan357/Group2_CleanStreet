# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/clean_street

# Session
SESSION_SECRET=change_me_in_production

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (optional; leave blank to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://admin.localhost:3000

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== ADMIN SETUP CONFIGURATION ==========
# Super Admin Credentials (for initial setup only)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=System Administrator

# Master key for protected setup endpoints
ADMIN_SETUP_KEY=
FORCE_PASSWORD_CHANGE=true
ENABLE_SUPER_ADMIN_2FA=true

# ========== CLOUDINARY CONFIGURATION ==========
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
